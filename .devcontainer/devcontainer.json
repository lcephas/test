// Alpine base — used to exercise the apk → pip-venv rung of the az install ladder.
// sshd is installed in the Dockerfile (the devcontainers/features/sshd:1 feature
// is Debian/Ubuntu-only and fails on non-apt distros).
{
	"name": "Alpine (apk → pip-venv az install)",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"hostRequirements": {
		"memory": "8gb"
	}
}
