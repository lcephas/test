// Fedora base — used to exercise the dnf → pip-venv rung of the az install ladder.
// sshd is installed in the Dockerfile (the devcontainers/features/sshd:1 feature is
// Debian/Ubuntu-only and fails on non-apt distros).
{
	"name": "Fedora (dnf → pip-venv az install)",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"hostRequirements": {
		"memory": "8gb"
	},
	"overrideCommand": false
}
